/* --- General background and text --- */
body {
    background-color: #f4f1e9; /* soft parchment color */
    color: #333333;
    font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
}

/* --- Header --- */
#header {
    background-color: #3e4e50; /* library bookshelf dark green */
    color: #f9f5f0;
}

#header h1, #header #user-tools {
    color: #f9f5f0;
}

/* --- Admin module cards --- */
.dashboard-module {
    background-color: #ffffff;
    border: 1px solid #d2cfc4;
    border-radius: 10px;
    padding: 15px;
    margin-bottom: 15px;
    box-shadow: 2px 2px 5px rgba(0,0,0,0.1);
    transition: transform 0.2s, box-shadow 0.2s;
}

/* Hover effect for modules */
.dashboard-module:hover {
    transform: translateY(-3px);
    box-shadow: 4px 4px 10px rgba(0,0,0,0.2);
}

/* --- Links --- */
a {
    color: #2c5f2d; /* library green */
    text-decoration: none;
}

a:hover {
    color: #6a994e; /* lighter green on hover */
    text-decoration: underline;
}

/* --- Table headers and filters --- */
th {
    background-color: #d2cfc4;
    color: #333333;
}

.filter {
    background-color: #e9e5dd;
    padding: 5px 10px;
    border-radius: 5px;
}

/* --- Form fields --- */
fieldset {
    background-color: #f9f5f0;
    border: 1px solid #d2cfc4;
    border-radius: 8px;
    padding: 10px;
    margin-bottom: 15px;
}

/* --- Buttons --- */
input[type="submit"], .button, .deletelink {
    background-color: #2c5f2d; /* library green */
    color: #f9f5f0;
    border-radius: 5px;
    border: none;
    padding: 5px 10px;
    font-weight: bold;
    cursor: pointer;
    transition: background-color 0.2s;
}

input[type="submit"]:hover, .button:hover, .deletelink:hover {
    background-color: #6a994e;
}

/* --- Admin search bar --- */
#searchbar {
    border: 1px solid #d2cfc4;
    padding: 5px;
    border-radius: 5px;
}

/* --- Footer --- */
#footer {
    background-color: #3e4e50;
    color: #f9f5f0;
    padding: 5px;
}